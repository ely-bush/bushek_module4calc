<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="bushek_module4calc.MainPage">

    <Grid RowDefinitions="Auto, Auto, *, *, Auto"
          ColumnDefinitions="*, *"
          ColumnSpacing="10"
          RowSpacing="10"
          Margin="15">

        <Label Text="BMI Calculator (NOT AN ACCURATE MEDICAL TOOL OR MEASUREMENT)"
               Grid.ColumnSpan="2"
               Grid.Row="0"
               FontSize="Medium"
               TextColor="Black"/>

        <Border Grid.Column="0"
                Grid.Row="1"
                x:Name="maleBorder"
                StrokeThickness="3"
                Stroke="Transparent"
                Margin="10">

            <Image Source="male.png"
                   x:Name="maleImg"
                   HeightRequest="350"/>

            <Border.GestureRecognizers>

                <TapGestureRecognizer x:Name="maleTap" Tapped="maleTap_Tapped"/>

            </Border.GestureRecognizers>

        </Border>

        <Border Grid.Column="1"
                Grid.Row="1"
                x:Name="femaleBorder"
                StrokeThickness="3"
                Stroke="Transparent"
                Margin="10">

            <Image Source="female.png"
                   HeightRequest="350"
                   />
            <Border.GestureRecognizers>

                <TapGestureRecognizer x:Name="femaleTap" Tapped="femaleTap_Tapped"/>

            </Border.GestureRecognizers>

        </Border>

        <Border Grid.ColumnSpan="2"
                Grid.Row="2"
                x:Name="heightBorder"
                Background="Transparent">

            <VerticalStackLayout VerticalOptions="Center">

                <Label Text="Height (Inches)"
                       FontSize="35"
                       HorizontalOptions="Center"/>

                <Slider x:Name="heightSlider"
                        Minimum="0"
                        Maximum="100"
                        Value="50"
                        ThumbColor="Purple"
                        ValueChanged="heightSlider_ValueChanged"/>

                <Label x:Name="heightLabel"
                       HorizontalTextAlignment="Center"
                       FontSize="25"
                       TextColor="Black"/>

            </VerticalStackLayout>

        </Border>

        <Border Grid.ColumnSpan="2"
                Grid.Row="3"
                x:Name="weightBorder"
                BackgroundColor="Transparent">

            <VerticalStackLayout VerticalOptions="Center">

                <Label Text="Weight (Lbs)"
                       HorizontalOptions="Center"
                       FontSize="35"/>

                <Slider x:Name="weightSlider"
                        Minimum="0"
                        Maximum="300"
                        Value="90"
                        ValueChanged="weightSlider_ValueChanged"
                        ThumbColor="Purple"/>

                <Label x:Name="weightLabel"
                          HorizontalTextAlignment="Center"
                          FontSize="25"
                          TextColor="Black"/>

            </VerticalStackLayout>

        </Border>

        <Button Grid.ColumnSpan="2"
                Grid.Row="4"
                x:Name="calculateBtn"
                Text="Calculate BMI"
                FontSize="Large"
                Clicked="calculateBtn_Clicked"/>

    </Grid>

</ContentPage>
